    <insert id="addRole" parameterType="com.user.pojo.Role">
        insert into sys_roles (rolename, role_key, role_desc) values (#{params.roleName}, #{params.roleKey}, #{params.roleDesc})
    </insert>

    <insert id="addRolePermission" parameterType="com.user.pojo.RolePermission">
        insert into sys_role_permissions (role_id, perm_id) values (#{params.roleId}, #{params.permissionId})
    </insert>

    <delete id="deleteRoleById">
        delete from sys_roles where id = #{roleId}
    </delete>

    <delete id="deleteRolePermissionById">
        delete from sys_role_permissions where role_id = #{roleId}
    </delete>

    <update id="updateRole" parameterType="com.user.pojo.RoleParams">
        update sys_roles set
        <if test="params.roleName != null and params.roleName != ''">
            rolename = #{params.roleName}
        </if>
        <choose>
            <when test="params.roleName != null and params.roleName != ''">
                , role_desc = #{params.roleDesc}
            </when>
            <otherwise>
                role_desc = #{params.roleDesc}
            </otherwise>
        </choose>


        where id = #{params.id}
    </update>

    <select id="queryPermissionByRoleId" parameterType="com.user.pojo.RoleParams" resultType="com.authorize.pojo.Permission">
        select * from public.sys_permissions where id in (select perm_id from public.sys_role_permissions where role_id = #{params.id})
    </select>

    <select id="queryRoleIdByUserName" parameterType="com.user.pojo.UserParams" resultType="com.user.pojo.Role">
        SELECT ur.role_id as id
        FROM sys_users u
        LEFT JOIN sys_user_roles ur ON u.id = ur.user_id
        where u.username = #{params.username}
    </select>

    <update id="modifyPassword">
        update sys_users set password = #{password} where username = #{username}
    </update>

    <select id="queryAllPermissById" parameterType="com.authorize.pojo.Permission" resultType="com.authorize.pojo.Permission">
        select * from public.sys_permissions where id = #{params.id}
    </select>

    <select id="queryAllPermisss" resultType="com.authorize.pojo.Permission">
        select * from public.sys_permissions
    </select>

</mapper>