<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.user.dao.UserMapper">

    <!-- 根据用户名查找用户 -->
    <select id="findByUsername" resultType="com.user.pojo.User">
        SELECT *
        FROM sys_users
        WHERE username = #{username}
    </select>

    <select id="queryRoleByUserId" resultType="com.user.pojo.Role">
        select * from sys_roles where id = #{id}
    </select>

</mapper>