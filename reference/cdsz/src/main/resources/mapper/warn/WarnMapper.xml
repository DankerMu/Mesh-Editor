<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.warn.dao.WarnMapper">
    <select id="queryWarnCount" parameterType="com.warn.pojo.WarnInfoEntity" resultType="int">
        select count(id) from public.warn_tab where inserttime > #{params.insertTime}
    </select>
    <select id="queryWarnInfo" parameterType="com.warn.pojo.WarnInfoEntity"  resultType="com.warn.pojo.WarnInfoEntity">
        select * from public.warn_tab where inserttime >= #{params.insertTime} order by inserttime
    </select>

</mapper>